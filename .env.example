# Supabase (obrigatorio para multi-user com login cloud)
# Obter em https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Claude API (Anthropic) - RECOMENDADO
# Obter em https://console.anthropic.com/settings/keys
VITE_CLAUDE_API_KEY=sk-ant-api03-...

# Gemini API (Google) - ALTERNATIVA
# Obter em https://ai.google.dev (gratis)
VITE_GEMINI_API_KEY=AIza...

# Nota: Se ambas as keys estiverem definidas, a Claude e preferida.
# Usuarios podem configurar suas proprias keys no app (Settings > Provider).
