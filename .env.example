# ============================================================
# V4 PIT WALL - Variaveis de ambiente
# ============================================================
# Copie para .env.local e preencha com seus valores
# NUNCA commite .env.local no git

# ---------- SUPABASE (multi-user cloud + sharing publico) ----------
# Obter em https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ---------- IA - APENAS UMA E OBRIGATORIA ----------
# Sistema usa automaticamente o melhor modelo por tarefa

# Claude API (Anthropic) - RECOMENDADO para qualidade
# Modelos: Opus 4.7, Sonnet 4.6, Haiku 4.5, Claude Design
# Obter em https://console.anthropic.com/settings/keys
VITE_CLAUDE_API_KEY=sk-ant-api03-...

# Gemini API (Google) - RECOMENDADO para multimodal + imagens
# Modelos: 3.1 Pro, Flash, Nano Banana (gera imagens)
# Obter gratis em https://ai.google.dev
VITE_GEMINI_API_KEY=AIza...

# OpenRouter - Desbloqueia 400+ modelos com 1 chave
# Inclui: GPT-5.4, Grok 4, Llama 4, Qwen 3.5, Mistral 3, DeepSeek-R1, Kimi K2, o3
# Obter em https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-...

# ============================================================
# OBSERVACOES:
# - Usuarios podem configurar as proprias keys no app (Settings)
# - Se env vars estiverem setadas, sao usadas como default
# - Multi-API simultaneamente: sistema auto-escolhe melhor modelo
# - Modo offline 100% funcional sem nenhuma key
# ============================================================
